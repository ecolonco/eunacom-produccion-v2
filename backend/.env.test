# Test Environment Configuration
NODE_ENV=test
PORT=3001
LOG_LEVEL=error

# Test Database
DATABASE_URL="postgresql://jorgeaguilera@localhost:5432/eunacom_test"

# Test Redis
REDIS_URL="redis://localhost:6379/1"

# JWT Secrets (Test)
JWT_SECRET="test-jwt-secret-for-testing-only"
JWT_REFRESH_SECRET="test-refresh-secret-for-testing-only"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="1d"

# Session
SESSION_SECRET="test-session-secret-for-testing-only"

# CORS
CORS_ORIGIN="http://localhost:3001"

# Disable external services in tests
OPENAI_API_KEY=""
FLOW_API_KEY=""
SENDGRID_API_KEY=""

# Rate Limiting (Higher limits for tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# Feature Flags (Disabled for tests)
ENABLE_AI_GENERATION=false
ENABLE_PAYMENTS=false
ENABLE_EMAIL_NOTIFICATIONS=false

# Test-specific settings
AI_CONFIDENCE_THRESHOLD=0.90
MAX_QUESTION_VARIANTS=6
MEDICAL_REVIEW_REQUIRED=false
FREE_CREDITS_ON_SIGNUP=100
DAILY_FREE_QUESTIONS=10
CREDIT_COSTS_INDIVIDUAL=1
CREDIT_COSTS_SIMULATION=80
CREDIT_COSTS_REVIEW=15