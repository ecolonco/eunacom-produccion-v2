{
  "name": "eunacom-backend",
  "version": "1.0.0",
  "description": "EUNACOM Learning Platform - Backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmitOnError false && prisma generate && (prisma migrate deploy || (prisma migrate resolve --applied 20250927224855_exercise_factory_tables && prisma migrate deploy))",
    "start": "node dist/index.js",
    "start:test": "NODE_ENV=test tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "eunacom",
    "medical",
    "education",
    "api",
    "typescript",
    "express"
  ],
  "author": "EUNACOM Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@sendgrid/mail": "^8.1.6",
    "@types/multer": "^2.0.0",
    "@types/socket.io": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.34",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "openai": "^5.23.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@types/winston": "^2.4.4",
    "eslint": "^9.36.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
