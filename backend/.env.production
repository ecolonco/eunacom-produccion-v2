# EUNACOM Production Environment Configuration
# This file should be used as a template - actual values will be set in Render

# Server Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=warn

# Database (will be provided by Render PostgreSQL service)
DATABASE_URL=

# Redis (will be provided by Render Redis service or external)
REDIS_URL=

# JWT Secrets (MUST be changed for production)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Secret (MUST be changed for production)
SESSION_SECRET=

# CORS Configuration (your frontend domain)
CORS_ORIGIN=https://eunacom-frontend-v3.onrender.com,https://eunacom.app,https://www.eunacom.app

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# DeepSeek Configuration (for Exercise Factory)
DEEPSEEK_API_KEY=sk-8d786ad20758485899b4d587b14b19f2

# Flow.cl Payment Integration (Production)
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_SANDBOX=false
FLOW_BASE_URL=https://www.flow.cl

# SendGrid Email Service
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@eunacom.app
SENDGRID_FROM_NAME=EUNACOM Learning Platform

# File Upload Configuration
MAX_FILE_SIZE=10mb
UPLOAD_PATH=uploads/

# Rate Limiting (Production values)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100           # Lower limit for production

# Feature Flags
ENABLE_AI_GENERATION=true
ENABLE_PAYMENTS=true
ENABLE_EMAIL_NOTIFICATIONS=true

# Medical Content Configuration
AI_CONFIDENCE_THRESHOLD=0.90
MAX_QUESTION_VARIANTS=6
MEDICAL_REVIEW_REQUIRED=true

# Credit System
FREE_CREDITS_ON_SIGNUP=50
DAILY_FREE_QUESTIONS=3
CREDIT_COSTS_INDIVIDUAL=1
CREDIT_COSTS_SIMULATION=80
CREDIT_COSTS_REVIEW=15