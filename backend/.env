# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://jorgeaguilera@localhost:5432/eunacom_development"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (Development only - change in production)
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Session
SESSION_SECRET="dev-session-secret-change-in-production"

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# OpenAI Configuration (add your key when ready to test AI features)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"

# DeepSeek Configuration (for Exercise Factory)
DEEPSEEK_API_KEY="sk-8d786ad20758485899b4d587b14b19f2"

# Flow.cl Payment Integration (Sandbox mode)
FLOW_API_KEY=""
FLOW_SECRET_KEY=""
FLOW_SANDBOX=true
FLOW_BASE_URL="https://sandbox.flow.cl"

# SendGrid Email Service
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@eunacom.local"
SENDGRID_FROM_NAME="EUNACOM Learning Platform"

# File Upload Configuration
MAX_FILE_SIZE="10mb"
UPLOAD_PATH="uploads/"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=1000          # Higher limit for development

# Feature Flags
ENABLE_AI_GENERATION=false   # Disabled until OpenAI key is added
ENABLE_PAYMENTS=false        # Disabled until Flow.cl is configured
ENABLE_EMAIL_NOTIFICATIONS=false  # Disabled until SendGrid is configured

# Medical Content Configuration
AI_CONFIDENCE_THRESHOLD=0.90
MAX_QUESTION_VARIANTS=6
MEDICAL_REVIEW_REQUIRED=true

# Credit System
FREE_CREDITS_ON_SIGNUP=50
DAILY_FREE_QUESTIONS=3
CREDIT_COSTS_INDIVIDUAL=1
CREDIT_COSTS_SIMULATION=80
CREDIT_COSTS_REVIEW=15